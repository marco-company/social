<odoo>
    <record id="view_mail_mass_mailing_form" model="ir.ui.view">
        <field name="name">Add Prune button to Mass Mailing form view</field>
        <field name="model">mailing.mailing</field>
        <field name="inherit_id" ref="mass_mailing.view_mail_mass_mailing_form" />
        <field name="arch" type="xml">
            <xpath
                expr="//div[hasclass('o_mass_mailing_contact_list_ids')]"
                position="inside"
            >
                <field name="has_list_blacklisted_contacts" invisible="True" />
                <button
                    string="Prune Lists..."
                    name="show_prune_lists_wizard"
                    type="object"
                    attrs="{
                        'invisible': [
                            ('has_list_blacklisted_contacts', '=', False),
                        ],
                    }"
                />
            </xpath>
        </field>
    </record>
</odoo>
